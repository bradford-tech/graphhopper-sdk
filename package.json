{
  "name": "@bradford-tech/graphhopper-sdk",
  "version": "0.0.1",
  "description": "TypeScript SDK for the GraphHopper Directions API",
  "keywords": [
    "graphhopper",
    "api",
    "sdk",
    "typescript"
  ],
  "homepage": "https://github.com/bradford-tech/graphhopper-sdk#readme",
  "bugs": {
    "url": "https://github.com/bradford-tech/graphhopper-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bradford-tech/graphhopper-sdk.git"
  },
  "license": "MIT",
  "author": "Bradford Technologies <graphhopper-sdk@sargent.dev>",
  "sideEffects": [
    "./dist/client/client.gen.js"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "generate": "rimraf ./src/client && openapi-ts",
    "prepack": "npm run build",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.99.0",
    "jiti": "^2.7.0",
    "rimraf": "^6.1.3",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-config-flat-gitignore": "^2.3.0",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
